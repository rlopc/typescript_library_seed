{
  "name": "typescript-library-seed",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript seed project with best practices",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.6.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!**/node_modules\" \"!**/CHANGELOG.md\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"!**/node_modules\" \"!**/CHANGELOG.md\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "clean": "rimraf dist",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:publish": "publint --strict && attw --pack . --ignore-rules cjs-resolves-to-esm",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm run build && changeset publish",
    "commit": "cz",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build && pnpm run check:publish"
  },
  "keywords": [
    "typescript",
    "seed",
    "starter",
    "template",
    "boilerplate",
    "esm",
    "library"
  ],
  "author": "rlopc <rlopc4dev@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rlopc/typescript_library_seed.git"
  },
  "homepage": "https://github.com/rlopc/typescript_library_seed#readme",
  "bugs": {
    "url": "https://github.com/rlopc/typescript_library_seed/issues"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^67.0.0",
    "husky": "^9.1.7",
    "knip": "^6.17.1",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "publint": "^0.3.21",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
